# --- GLOBAL IGNORES ---
# Compiled class files
*.class
*.log
*.jar
*.war

# --- RECURSIVE BUILD DIRECTORIES ---
# This matches 'target' or 'build' in any sub-folder
**/target/
**/build/
**/out/

# --- MICROSERVICE SPECIFIC ---
# Ignore local configuration files in any service module
**/src/main/resources/application-local.properties
**/src/main/resources/application-local.yml
**/.env

# --- GRADLE/MAVEN ROOT ---
.gradle/
.mvn/
!**/.mvn/wrapper/maven-wrapper.jar
!**/.mvn/wrapper/maven-wrapper.properties

# --- IDEs ---
.idea/
.vscode/
*.iml
.classpath
.project
.settings/
MODEL.md
workspace.code-workspace
docker-push.sh
